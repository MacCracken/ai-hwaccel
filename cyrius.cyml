[package]
name = "ai-hwaccel"
version = "${file:VERSION}"
description = "Hardware accelerator detection and planning for AI workloads"
license = "GPL-3.0-only"
language = "cyrius"
cyrius = "5.11.8"
repository = "https://github.com/MacCracken/ai-hwaccel"

[build]
entry = "src/main.cyr"
output = "ai-hwaccel"

[deps]
stdlib = ["string", "alloc", "vec", "str", "fmt", "io", "syscalls", "fs", "tagged", "process", "args", "fnptr", "thread", "assert", "bench", "freelist", "hashmap", "json"]
