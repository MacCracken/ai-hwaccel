#   ai-hwaccel                  # Full registry JSON
#   ai-hwaccel --summary        # Compact summary JSON
#   ai-hwaccel --table          # Human-readable table
#   ai-hwaccel --cost 70B       # Cloud instance recommendation
#   ai-hwaccel --version        # Print version

