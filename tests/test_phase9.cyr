# --- JSON output tests ---

fn test_profile_json() {
    var p = profile_cuda(0, 24 * BYTES_PER_GIB);
    profile_set_device_name(p, "RTX 4090");
    profile_set_compute_cap(p, "8.9");

    var sb = str_builder_new();
    profile_to_json(sb, p);
    var json = str_builder_build(sb);
    var js = str_from(str_data(json));

    # Should contain key fields
    assert(str_contains(js, str_from("accelerator")) == 1, "has accelerator");
    assert(str_contains(js, str_from("CUDA GPU")) == 1, "has CUDA GPU");
    assert(str_contains(js, str_from("available")) == 1, "has available");
    assert(str_contains(js, str_from("true")) == 1, "available true");
    assert(str_contains(js, str_from("memory_bytes")) == 1, "has memory");
    assert(str_contains(js, str_from("RTX 4090")) == 1, "has device name");
    assert(str_contains(js, str_from("8.9")) == 1, "has CC");
    return 0;
}

fn test_registry_json() {
    var profiles = vec_new();
    vec_push(profiles, profile_cpu(16 * BYTES_PER_GIB));
    vec_push(profiles, profile_cuda(0, 24 * BYTES_PER_GIB));
    var r = registry_from_profiles(profiles);

    var json = registry_to_json(r);
    var js = str_from(str_data(json));

    assert(str_contains(js, str_from("schema_version")) == 1, "has schema");
    assert(str_contains(js, str_from("profiles")) == 1, "has profiles");
    assert(str_contains(js, str_from("CPU")) == 1, "has CPU");
    assert(str_contains(js, str_from("CUDA GPU")) == 1, "has CUDA");
    return 0;
}

fn test_summary_json() {
    var profiles = vec_new();
    vec_push(profiles, profile_cpu(64 * BYTES_PER_GIB));
    vec_push(profiles, profile_cuda(0, 24 * BYTES_PER_GIB));
    vec_push(profiles, profile_cuda(1, 24 * BYTES_PER_GIB));
    var r = registry_from_profiles(profiles);

    var json = registry_to_summary_json(r);
    var js = str_from(str_data(json));

    assert(str_contains(js, str_from("device_count")) == 1, "has device_count");
    assert(str_contains(js, str_from("has_accelerator")) == 1, "has has_accel");
    assert(str_contains(js, str_from("true")) == 1, "accel true");
    assert(str_contains(js, str_from("gpu_count")) == 1, "has gpu_count");
    return 0;
}

fn test_json_optional_fields() {
    # CPU profile — no optional fields set
    var p = profile_cpu(16 * BYTES_PER_GIB);
    var sb = str_builder_new();
    profile_to_json(sb, p);
    var json = str_builder_build(sb);
    var js = str_from(str_data(json));

    # Should NOT contain optional fields
    assert(str_contains(js, str_from("device_name")) == 0, "no device_name for CPU");
    assert(str_contains(js, str_from("temperature_c")) == 0, "no temp for CPU");
    assert(str_contains(js, str_from("numa_node")) == 0, "no numa for CPU");
    return 0;
}

fn test_json_with_warnings() {
    var profiles = vec_new();
    vec_push(profiles, profile_cpu(16 * BYTES_PER_GIB));
    var r = registry_from_profiles(profiles);

    # Add a warning
    var warns = reg_warnings(r);
    vec_push(warns, warning_tool_not_found("nvidia-smi"));

    var json = registry_to_json(r);
    var js = str_from(str_data(json));

    assert(str_contains(js, str_from("warnings")) == 1, "has warnings");
    assert(str_contains(js, str_from("nvidia-smi")) == 1, "warning content");
    return 0;
}

fn test_binary_size() {
    # Verify the compiled binary exists and is reasonable size
    # (this test is about the compilation itself succeeding)
    assert(1 == 1, "compilation succeeded");
    return 0;
}

# --- Run all tests ---

alloc_init();

test_profile_json();
test_registry_json();
test_summary_json();
test_json_optional_fields();
test_json_with_warnings();
test_binary_size();

var fails = assert_summary();
syscall(60, fails);
