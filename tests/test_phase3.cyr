# test_phase3.cyr — tests for Phase 3 subprocess execution & platform helpers
# Tests: which(), run_tool(), sysfs helpers, CSV parsing, system memory

include "lib/string.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/fmt.cyr"
include "lib/assert.cyr"
include "lib/io.cyr"
include "lib/syscalls.cyr"
include "lib/fs.cyr"
include "lib/tagged.cyr"
include "lib/process.cyr"

include "src/units.cyr"
include "src/error.cyr"
include "src/types.cyr"
include "src/quantization.cyr"
include "src/profile.cyr"
include "src/system_io.cyr"
include "src/detect/platform.cyr"
include "src/detect/command.cyr"

# --- which() tests ---

fn test_which_echo() {
    var path = which("echo");
    assert(path != 0, "which(echo) found");
    # Should be an absolute path starting with /
    assert_eq(load8(path), 47, "echo path starts with /");
    return 0;
}

fn test_which_missing() {
    var path = which("nonexistent_tool_xyz_12345");
    assert_eq(path, 0, "which(missing) returns 0");
    return 0;
}

# --- run_tool tests ---

fn test_run_echo() {
    var warnings = vec_new();
    var args = vec_new();
    vec_push(args, "hello");
    var result = run_tool("echo", args, warnings);
    assert(result != 0, "echo returns output");
    assert_eq(vec_len(warnings), 0, "no warnings");
    # Output should contain "hello"
    var sdata = str_data(result);
    assert(memeq(sdata, "hello", 5) == 1, "echo output");
    return 0;
}

fn test_run_missing_tool() {
    var warnings = vec_new();
    var args = vec_new();
    var result = run_tool("nonexistent_tool_xyz", args, warnings);
    assert_eq(result, 0, "missing tool returns 0");
    assert_eq(vec_len(warnings), 1, "1 warning");
    var w = vec_get(warnings, 0);
    assert_eq(warning_code(w), ERR_TOOL_NOT_FOUND, "tool not found warning");
    return 0;
}

# --- CSV parsing tests ---

fn test_parse_csv_line() {
    var line = str_from("0, 81920, 512, 81408, 8.9, 550.54, RTX 4090");
    var fields = parse_csv_line(line, 6);
    assert(fields != 0, "parsed CSV");
    assert_eq(vec_len(fields), 7, "7 fields");
    # First field — parse as int since Str is not null-terminated
    var f0 = vec_get(fields, 0);
    assert_eq(str_to_int(f0), 0, "field 0 = 0");
    # Second field
    var f1 = vec_get(fields, 1);
    assert_eq(str_to_int(f1), 81920, "field 1 = 81920");
    # Check str equality with Str
    var expected = str_from("81920");
    assert_eq(str_eq(f1, expected), 1, "field 1 str eq");
    return 0;
}

fn test_parse_csv_too_few() {
    var line = str_from("one, two");
    var fields = parse_csv_line(line, 5);
    assert_eq(fields, 0, "too few fields returns 0");
    return 0;
}

# --- Validation tests ---

fn test_validate_device_id() {
    var s0 = str_from("0");
    assert_eq(validate_device_id(s0), 0, "id 0 valid");

    var s7 = str_from("7");
    assert_eq(validate_device_id(s7), 7, "id 7 valid");

    var s9999 = str_from("9999");
    assert_eq(validate_device_id(s9999), 0 - 1, "id 9999 invalid");
    return 0;
}

fn test_validate_memory_mb() {
    var s1024 = str_from("81920");
    assert_eq(validate_memory_mb(s1024), 81920, "81920 MB valid");

    var huge = str_from("999999999");
    assert_eq(validate_memory_mb(huge), 0 - 1, "huge mem invalid");
    return 0;
}

# --- sysfs tests ---

fn test_sysfs_read_proc() {
    # /proc/sys/kernel/pid_max should exist and be readable
    var s = sysfs_read("/proc/sys/kernel/pid_max");
    assert(s != 0, "pid_max readable");
    var val = str_to_int(s);
    assert(val > 0, "pid_max > 0");
    return 0;
}

fn test_sysfs_read_int() {
    var val = sysfs_read_int("/proc/sys/kernel/pid_max");
    assert(val > 0, "pid_max int > 0");
    return 0;
}

fn test_sysfs_read_missing() {
    var s = sysfs_read("/sys/nonexistent/path/xyz");
    assert_eq(s, 0, "missing path returns 0");
    return 0;
}

fn test_path_exists() {
    assert_eq(path_exists("/proc/self/status"), 1, "/proc/self/status exists");
    assert_eq(path_exists("/nonexistent_xyz"), 0, "nonexistent path");
    return 0;
}

# --- System memory ---

fn test_detect_system_memory() {
    var mem = detect_system_memory();
    assert(mem > 0, "system memory > 0");
    # Should be at least 512 MB
    assert(mem > 512 * 1024 * 1024, "system memory > 512 MB");
    return 0;
}

# --- sysfs path building ---

fn test_sysfs_path() {
    var p = sysfs_path("/sys/class/drm", "card0", "device/vendor");
    assert(streq(p, "/sys/class/drm/card0/device/vendor") == 1, "sysfs path");

    var p2 = sysfs_path("/sys/class/misc", "intel_npu", 0);
    assert(streq(p2, "/sys/class/misc/intel_npu") == 1, "sysfs path no suffix");

    var p3 = sysfs_path("/dev", 0, 0);
    assert(streq(p3, "/dev/") == 1, "sysfs path base only");
    return 0;
}

# --- parse_value_with_suffix ---

fn test_parse_value_suffix() {
    var s1 = str_from("44 GB");
    assert_eq(parse_value_with_suffix(s1), 44, "44 GB");

    var s2 = str_from("  81920  ");
    assert_eq(parse_value_with_suffix(s2), 81920, "81920 trimmed");

    var s3 = str_from("900MB");
    assert_eq(parse_value_with_suffix(s3), 900, "900MB");
    return 0;
}

# --- Run all tests ---

alloc_init();

test_which_echo();
test_which_missing();
test_parse_csv_line();
test_parse_csv_too_few();
test_validate_device_id();
test_validate_memory_mb();
test_sysfs_read_proc();
test_sysfs_read_int();
test_sysfs_read_missing();
test_path_exists();
test_detect_system_memory();
test_sysfs_path();
test_parse_value_suffix();
